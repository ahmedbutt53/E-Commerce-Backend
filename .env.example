# Firebase Configuration (create serviceAccountKey.json locally or set as env variable)
# On Vercel, you need to add these as environment variables in your project settings:

# Option 1: Upload serviceAccountKey.json locally (for development)
# serviceAccountKey.json should be in the root directory

# Option 2: Set Firebase credentials as environment variable (for Vercel)
# FIREBASE_SERVICE_ACCOUNT_KEY="{paste your serviceAccountKey.json content}"
# FIREBASE_DATABASE_URL="https://your-project.firebaseio.com"

NODE_ENV=production
